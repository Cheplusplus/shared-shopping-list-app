# Copy this file to `.env` and fill in the values from your Firebase
# project's web app config (Firebase console -> Project settings -> General
# -> "Your apps" -> Web app -> SDK setup and configuration -> Config).
# See SETUP.md for the full walkthrough.
#
# Vite only exposes env vars prefixed with VITE_ to client code, and only
# reads .env at dev-server/build time — restart `npm run dev` after editing.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# App Check (reCAPTCHA v3). Required: Cloud Storage has App Check enforcement
# turned on, so uploads fail with `storage/unauthenticated` without a valid
# App Check token. This is the reCAPTCHA v3 *site key* (the public one) —
# Firebase console -> App Check -> Apps -> this web app -> reCAPTCHA v3, or the
# Google reCAPTCHA admin console. Not secret; it ships in client code.
VITE_FIREBASE_RECAPTCHA_SITE_KEY=

# Optional: a fixed App Check debug token for local dev, so localhost (which
# can't pass a real reCAPTCHA) is accepted. Register it under App Check -> Apps
# -> Manage debug tokens. Leave blank to have the SDK generate and print a
# fresh one in the console on each machine (dev builds only).
VITE_APPCHECK_DEBUG_TOKEN=

# Web Push (FCM) public key, for the "ping" push notifications. Firebase
# console -> Project settings -> Cloud Messaging -> Web configuration ->
# "Web Push certificates" -> the "Key pair" value. Optional: leave blank to
# ship without push (the ping UI then reports that this device can't receive).
VITE_FIREBASE_VAPID_KEY=
